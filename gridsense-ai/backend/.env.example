# ── GridSense AI — Backend Environment Variables ──────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit the actual .env file to git.

# Database (SQLite for dev/prod-lite, swap for Postgres in heavy prod)
DATABASE_URL=sqlite:///./gridsense.db

# Security
SECRET_KEY=change-me-to-a-long-random-string

# App
ENVIRONMENT=development        # development | production
ALLOWED_ORIGINS=*              # In production: set to your frontend URL
LOG_LEVEL=INFO
SYNTHETIC_DATA_BANNER=true

# ── Gemini LLM ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_PRIMARY_MODEL=gemini-2.0-flash
GEMINI_REPORT_MODEL=gemini-1.5-pro
LLM_ENABLED=true
LLM_MAX_RETRIES=3
LLM_TIMEOUT_SECONDS=15
LLM_MOCK_MODE=true             # Set to false in production to use real Gemini
